# Copy to .env. The app runs fully with ONLY DATABASE_URL set (everything else
# falls back to built-in simulators / a deterministic demo AI brain).

# --- Required ---
# Local Postgres + pgvector (preferred). Create with: createdb fieldflow
DATABASE_URL="postgresql://USER@localhost:5432/fieldflow?schema=public"
# Legacy zero-setup option (no vector/RAG support): DATABASE_URL="file:./dev.db"

# --- AI brain (optional) ---
# Set a real key to switch the receptionist + SMS qualifier to live Claude Haiku.
# Get one at https://console.anthropic.com . Leave blank to use the demo brain.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# --- Production integrations (optional) ---
# Empty values => simulated adapters so the full demo works with no accounts.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""   # e.g. +18885551234 (A2P-registered, one per client)
CALCOM_API_KEY=""       # https://cal.com booking
VAPI_API_KEY=""         # https://vapi.ai inbound voice (production voice path)
