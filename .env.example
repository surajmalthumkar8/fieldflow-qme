# Copy to .env. Shared by the Next.js app (frontend/) and the FastAPI service (backend/).
# Only DATABASE_URL is strictly required; everything else has a sensible default or
# falls back to a local/simulated path.

# ── Required: Database (Postgres + pgvector) ──
# Create with: createdb fieldflow  +  CREATE EXTENSION vector;
DATABASE_URL="postgresql://USER@localhost:5432/fieldflow?schema=public"

# ── AI/voice microservice (FastAPI + local Ollama). Blank = frontend skips it. ──
AI_SERVICE_URL="http://localhost:8000"

# ── Email: send calendar invites (.ics) over SMTP. Blank = invites are download-only. ──
# Gmail: enable 2FA, then create an App Password and use it as SMTP_PASSWORD.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"        # or SMTP_USERNAME — both accepted
SMTP_PASSWORD=""                 # Gmail App Password (16 chars)
SMTP_FROM="you@gmail.com"

# ── Backend (FastAPI) — optional, sensible defaults ──
# OLLAMA_HOST="http://localhost:11434"
# JWT_SECRET="change-me-in-production"   # set a strong value before going live

# ── Optional cloud fallbacks (leave blank to stay fully local / $0) ──
# Live Claude brain for the Next.js demo + reactivation paths (else deterministic demo brain):
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
# SMS / booking adapters (simulated when blank):
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""   # preferred (A2P 10DLC number pool); else use a from-number
TWILIO_FROM_NUMBER=""             # e.g. +18885551234 (A2P-registered)
CALCOM_API_KEY=""                 # https://cal.com booking
